# Spotify user ID — from your profile URL: https://open.spotify.com/user/<ID>
PUBLIC_SPOTIFY_USER_ID=

# Spotify profile image URL — right-click your avatar on Spotify and copy image URL
PUBLIC_SPOTIFY_USER_IMAGE=

# Comma-separated public playlist IDs — from playlist URLs: https://open.spotify.com/playlist/<ID>
PUBLIC_SPOTIFY_PLAYLIST_IDS=
